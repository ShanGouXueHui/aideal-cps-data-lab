HZ12_WORKER_NAME=product_all_full
HZ12_CDP_PORT=19228

# 商品推广 / 全部商品页面
HZ12_URL_TEMPLATE=https://union.jd.com/proManager/index?pageNo={page_no}

# 页面显示约 4000 条；20 条/页则约 200 页。这里留冗余。
HZ12_PAGE_START=1
HZ12_PAGE_MAX=260
HZ12_TARGET_TOTAL=4000

# 单轮节奏：低频，避免风控
HZ12_ITEMS_PER_PAGE_LIMIT=20
HZ12_ITEM_SLEEP_MIN=7
HZ12_ITEM_SLEEP_MAX=16
HZ12_PAGE_SLEEP_MIN=5
HZ12_PAGE_SLEEP_MAX=12

# 刷新周期：短链 60 天有效，提前 20 天刷新，即 40 天刷新
HZ12_LINK_EXPIRE_DAYS=60
HZ12_REFRESH_AFTER_DAYS=40
HZ12_SLEEP_CHECK_SECONDS=1800

HZ12_MAX_FAIL_STREAK=3
HZ12_EMPTY_PAGE_LIMIT=8

HZ12_OUT_PREFIX=hz_jd_union_product_all_full_links
