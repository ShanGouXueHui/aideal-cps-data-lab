{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidealfy.com/schemas/aideal-cps-product-feed-v1.schema.json",
  "title": "AIdeal CPS Product Feed Row V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "sku",
    "title",
    "item_url",
    "promotion_url",
    "image_url",
    "price",
    "status",
    "source_round_id",
    "source_updated_at",
    "source_payload_hash"
  ],
  "properties": {
    "schema_version": {"const": "aideal-cps-product-feed/v1"},
    "source": {"const": "jd_union_datalab"},
    "sku": {"type": "string", "pattern": "^[0-9]{5,32}$"},
    "title": {"type": "string", "minLength": 1, "maxLength": 255},
    "description": {"type": ["string", "null"]},
    "item_url": {"type": "string", "pattern": "^https://item\\.jd\\.com/[0-9]+\\.html"},
    "promotion_url": {"type": "string", "pattern": "^https://u\\.jd\\.com/"},
    "short_url": {"type": ["string", "null"]},
    "long_url": {"type": ["string", "null"]},
    "qr_url": {"type": ["string", "null"]},
    "jd_command": {"type": ["string", "null"]},
    "image_url": {"type": "string", "minLength": 1},
    "category_name": {"type": ["string", "null"]},
    "shop_name": {"type": ["string", "null"]},
    "price": {"type": ["string", "number"]},
    "coupon_price": {"type": ["string", "number", "null"]},
    "commission_rate": {"type": ["string", "number", "null"]},
    "estimated_commission": {"type": ["string", "number", "null"]},
    "sales_volume": {"type": ["integer", "string", "null"]},
    "coupon_info": {"type": ["string", "null"]},
    "status": {"enum": ["active", "inactive"]},
    "link_created_at": {"type": ["string", "null"]},
    "link_expire_at": {"type": ["string", "null"]},
    "refresh_due_at": {"type": ["string", "null"]},
    "last_checked_at": {"type": ["string", "null"]},
    "last_seen_at": {"type": ["string", "null"]},
    "source_round_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "source_run_id": {"type": ["string", "null"]},
    "source_page_no": {"type": ["integer", "null"], "minimum": 1, "maximum": 67},
    "source_updated_at": {"type": "string", "minLength": 1},
    "catalog_change_count": {"type": "integer", "minimum": 0},
    "source_payload_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
